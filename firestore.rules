rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidFriendCode(data) {
      return data.keys().hasAll(['genres', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.genres is list &&
             data.createdAt is number;
    }

    function isValidWatchHistory(data) {
      return data.keys().hasAll(['id', 'title', 'poster', 'genres', 'watchedAt']) &&
             data.keys().size() == 5 &&
             data.id is number &&
             data.title is string &&
             data.poster is string &&
             data.genres is list &&
             data.watchedAt is number;
    }

    match /friendCodes/{codeId} {
      allow read: if true;
      allow create, update: if isValidFriendCode(request.resource.data);
      allow delete: if false;
    }

    match /watchHistory/{movieId} {
      allow read: if true;
      allow create, update: if isValidWatchHistory(request.resource.data);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
